        {
          "phrases": [],
          "ensureSequenceFinish": false,
          "generateOnce": true,
          "bias": 0,
          "enabled": true,
          "whenInactive": false
        }
      ],
      "advancedConditions": []
    },
    {
      "text": "A rural community of 800 people known for dairy monster girls and generational farms. This is where Alvis's grandfather's farm is located and was once a respected figure in the community.",
      "contextConfig": {
        "prefix": "----\n",
        "suffix": "\n",
        "tokenBudget": 1,
